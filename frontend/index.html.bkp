<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>YT-DLP</title>

<style>
body {
    font-family: Arial, sans-serif;
    max-width: 900px;
    margin: auto;
}
input, select, button {
    padding: 6px;
}
pre {
    background: #111;
    color: #0f0;
    padding: 10px;
}
ul {
    list-style: none;
    padding: 0;
}
li {
    margin-bottom: 6px;
}
button.delete {
    margin-left: 10px;
    color: red;
}
</style>
</head>

<body>

<h2>YT-DLP Downloader</h2>

<input id="url" size="60" placeholder="URL do vídeo">
<select id="format">
    <option value="mp4">MP4</option>
    <option value="mp3">MP3</option>
</select>
<button onclick="startDownload()">Baixar</button>

<h3>Status</h3>
<pre id="progress">idle</pre>

<h3>Arquivos</h3>
<ul id="files"></ul>

<script>
function startDownload() {
    fetch('/api/download', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({
            url: url.value,
            format: format.value
        })
    });
}

function loadFiles() {
    fetch('/api/files')
        .then(r => r.json())
        .then(files => {
            filesEl.innerHTML = '';
            files.forEach(f => {
                let li = document.createElement('li');
                li.innerHTML = `
                    <a href="/downloads/${f}">${f}</a>
                    <button class="delete" onclick="del('${f}')">apagar</button>
                `;
                filesEl.appendChild(li);
            });
        });
}

function del(name) {
    if (!confirm("Apagar arquivo?")) return;

    fetch('/api/delete', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({name})
    }).then(loadFiles);
}

const filesEl = document.getElementById('files');

setInterval(loadFiles, 3000);
loadFiles();

const evt = new EventSource('/api/progress');
evt.onmessage = e => {
    progress.textContent = e.data;
};
</script>

</body>
</html>
